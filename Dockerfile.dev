# Dev image: hot-reload via `next dev`, source bind-mounted from host.
FROM node:22-alpine
RUN corepack enable
WORKDIR /app

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

# package.json is bind-mounted at runtime. Run `pnpm install` on every
# start so a changed package.json or new lockfile is picked up; pnpm is
# a fast no-op when node_modules is already in sync. Call `next dev`
# via `pnpm exec` to avoid pnpm's `--` arg forwarding quirks.
CMD ["sh", "-c", "pnpm install && pnpm exec next dev --hostname 0.0.0.0"]
