# Dev image: hot-reload via `next dev`, source bind-mounted from host.
FROM node:22-alpine
RUN corepack enable
WORKDIR /app

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

# Install + migrate are run as separate one-shot compose services that
# the `app` service waits on, so the dev container itself just serves.
CMD ["pnpm", "exec", "next", "dev", "--hostname", "0.0.0.0"]
