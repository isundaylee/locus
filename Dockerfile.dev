# Dev image: hot-reload via `next dev`, source bind-mounted from host.
FROM node:22-alpine
WORKDIR /app

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

# package.json is bind-mounted at runtime. Always run `npm install` so a
# changed package.json is picked up automatically; npm is a no-op fast path
# when node_modules is already in sync.
CMD ["sh", "-c", "npm install && npm run dev -- --hostname 0.0.0.0"]
